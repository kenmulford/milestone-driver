# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Logs and scratch
*.log
/tmp/
/scratch/

# milestone-driver per-clone runtime markers (under .milestone-config/, gitignored).
# NOTE: the committed profile .milestone-config/driver.json is NOT ignored — never add a
# blanket /.milestone-config/ ignore here.
/.milestone-config/tests-stamp
/.milestone-config/preflight-notice
/.milestone-config/trello-notice
/.milestone-config/triage-cache.json
/.milestone-config/worktrees/

# milestone-feeder per-run scratch (plan file + needs-input report + authoring temp
# bodies). Per-clone scratch the user reviews then deploys via create; never committed.
/.milestone-feeder/

# milestone-bootstrapper per-run scratch (the provisioning plan file). Per-clone scratch
# the user reviews then deploys via apply; never committed. (Analog of /.milestone-feeder/.)
/.milestone-bootstrapper/

# Legacy root marker paths (transitional, pre-v1.9.1). Kept so leftover files in an
# existing clone stay ignored during the read-old / clean-up migration; safe to drop
# once no clone carries them.
/.milestone-driver-tests-stamp
/.milestone-driver-preflight-notice
/.milestone-driver-trello-notice
/.milestone-driver-triage-cache.json
.milestone-driver-worktrees/
